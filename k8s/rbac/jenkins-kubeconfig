apiVersion: v1
kind: Config

clusters:
- cluster:
    server: https://127.0.0.1:43803
    insecure-skip-tls-verify: true
  name: kind-cluster

contexts:
- context:
    cluster: kind-cluster
    namespace: dev
    user: jenkins-deployer
  name: jenkins-context

current-context: jenkins-context

users:
- name: jenkins-deployer
  user:
    token: YOUR_TOKEN
